---
import Layout from '../layouts/Layout.astro';
import { musicArticles } from '../data/music';
import { resumeData } from '../data/resume';

const currentJob = resumeData[0];
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-atomic">✦</div>
    <p class="hero-greeting">Welcome to the orbital</p>
    <h1 class="hero-name starburst">Sha Razeek</h1>
    <p class="hero-role">Developer · Hypermedia Specialist · UI/UX Designer</p>
    <div class="hero-divider">
      <span class="divider-star">◈</span>
    </div>
    <p class="hero-desc">
      Just an ordinary guy who loves building beautiful things.

    </p>
    <div class="hero-actions">
      <a href="/portfolio" class="btn btn--primary">View Portfolio</a>
      <a href="/about" class="btn">About Me</a>
    </div>
  </section>

  <!-- Projects Section -->
  <section class="section">
    <div class="section-header">
      <h2>Projects</h2>
    </div>
    <div class="apps-container stagger">
      <a href="/music/transistor" class="app-promo-card app-promo-card--transistor">
        <div class="app-promo-content">
          <p class="app-promo-desc">Global radio broadcasting at your fingertips. Tuned to thousands of stations worldwide with a retro-futuristic interface.</p>
        </div>
        <div class="app-promo-visual">
          <div class="app-promo-overlay">
            <span class="app-promo-icon">📻</span>
            <div class="app-promo-title-group">
              <h3 class="app-promo-title">Transistor</h3>
              <span class="app-promo-tag">Radio Receiver</span>
            </div>
          </div>
          <div class="visual-waves">
            <span></span><span></span><span></span>
          </div>
        </div>
      </a>

      <a href="/projects/broadcast" class="app-promo-card app-promo-card--broadcast">
        <div class="app-promo-content">
          <p class="app-promo-desc">Direct satellite transmission from across the globe. Seamless streaming of live international television channels.</p>
        </div>
        <div class="app-promo-visual">
          <div class="app-promo-overlay">
            <span class="app-promo-icon">📺</span>
            <div class="app-promo-title-group">
              <h3 class="app-promo-title">Broadcast</h3>
              <span class="app-promo-tag">Live TV Receiver</span>
            </div>
          </div>
          <div class="visual-test-pattern"></div>
        </div>
      </a>
    </div>
  </section>

  <!-- Recently Written -->
  <section class="section">
    <div class="section-header">
      <h2>Recently Written</h2>
      <a href="/blog" class="section-link">All Articles →</a>
    </div>
    <div class="articles-grid stagger">
      {musicArticles.slice(0, 4).map((article) => (
        <a href={`/blog/${article.slug}`} class="card article-card">
          <div class="article-card-image" style={`background: ${article.heroColor}`}>
          </div>
          <div class="article-card-body">
            <span class="tag">{article.genre}</span>
            <h3>{article.title}</h3>
            <p>{article.excerpt}</p>
            <span class="article-date">{article.date}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Quick Links -->
  <section class="section">
    <div class="section-header">
      <h2>Explore</h2>
    </div>
    <div class="explore-grid stagger">
      <a href="/music" class="explore-card">
        <span class="explore-icon">♪</span>
        <span class="explore-label">Music</span>
        <span class="explore-desc">Playlists & writing</span>
      </a>
      <a href="/trivia" class="explore-card">
        <span class="explore-icon">⬡</span>
        <span class="explore-label">Trivia</span>
        <span class="explore-desc">Weekly quizzes</span>
      </a>
      <a href="/portfolio" class="explore-card">
        <span class="explore-icon">◎</span>
        <span class="explore-label">Portfolio</span>
        <span class="explore-desc">Selected works</span>
      </a>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
    position: relative;
  }

  .hero-atomic {
    font-size: 1.5rem;
    color: var(--accent-secondary);
    animation: atomicSpin 10s linear infinite;
    margin-bottom: 1.5rem;
    display: inline-block;
  }

  .hero-greeting {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-warm-gray);
    margin-bottom: 0.75rem;
  }

  .hero-name {
    font-size: 5.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
    background: linear-gradient(
      135deg, 
      var(--color-dark) 0%, 
      var(--accent-primary) 25%, 
      var(--accent-secondary) 50%, 
      var(--accent-primary) 75%, 
      var(--color-dark) 100%
    );
    background-size: 400% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmeryText 12s linear infinite;
  }

  @keyframes shimmeryText {
    0% { background-position: 0% 50%; }
    100% { background-position: 400% 50%; }
  }

  .hero-role {
    font-size: 1.3rem;
    color: var(--text-secondary);
    font-weight: 300;
    margin-bottom: 1.5rem;
  }

  .hero-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .hero-divider::before,
  .hero-divider::after {
    content: '';
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-warm-gray), transparent);
  }

  .divider-star {
    color: var(--accent-primary);
    font-size: 0.75rem;
  }

  .hero-desc {
    max-width: 640px;
    margin: 0 auto 2.5rem;
    color: var(--text-secondary);
    font-size: 1.15rem;
  }

  .hero-actions {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Sections */
  .section {
    margin-top: 4rem;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    font-size: 1.8rem;
    margin-bottom: 0;
  }

  .section-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Article Cards */
  .article-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    padding: 0;
    overflow: hidden;
  }

  .article-card:hover {
    color: inherit;
  }

  .article-card-image {
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .article-card-icon {
    font-size: 2rem;
    color: white;
    opacity: 0.9;
  }

  .article-card-body {
    padding: 1.25rem;
  }

  .article-card-body h3 {
    font-size: 1.175rem;
    margin: 0.5rem 0;
  }

  .article-card-body p {
    font-size: 1.05rem;
    margin-bottom: 0.75rem;
  }

  .article-date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-warm-gray);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Explore Grid */
  .explore-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  /* App Promo Cards */
  .apps-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .app-promo-card {
    display: flex;
    flex-direction: column-reverse;
    background: white;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: all var(--transition-medium);
  }

  .app-promo-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--accent-primary);
  }

  .app-promo-content {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .app-promo-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    padding: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    z-index: 10;
    background: linear-gradient(to right, rgba(0,0,0,0.4) 0%, transparent 70%);
  }

  .app-promo-icon {
    font-size: 5rem;
  }

  .app-promo-title {
    font-size: 2.25rem;
    margin: 0;
    line-height: 1.1;
    color: white;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
  }

  .app-promo-tag {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.8);
    display: block;
    margin-top: 0.25rem;
  }

  .app-promo-desc {
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 680px;
    margin-bottom: 0;
  }

  .app-promo-visual {
    height: 300px;
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border-color);
  }

  .app-promo-card--transistor .app-promo-visual {
    background: linear-gradient(135deg, var(--accent-primary), var(--color-sage));
  }

  .app-promo-card--broadcast .app-promo-visual {
    background: linear-gradient(135deg, var(--color-charcoal), var(--color-teal));
    justify-content: flex-end;
    padding-right: 0;
  }

  /* Visual Elements */
  .visual-waves {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    width: 100%;
    height: 100%;
    padding-right: 0;
  }

  .visual-waves span {
    position: absolute;
    right: -100px;
    width: 200px;
    height: 200px;
    border: 4px solid rgba(255,255,255,0.3);
    border-radius: 50%;
    animation: wavePulse 5s linear infinite;
    opacity: 0;
  }

  .visual-waves span:nth-child(1) { animation-delay: 0s; }
  .visual-waves span:nth-child(2) { animation-delay: 1.66s; }
  .visual-waves span:nth-child(3) { animation-delay: 3.33s; }

  @keyframes wavePulse {
    0% { transform: scale(1); opacity: 0.7; }
    100% { transform: scale(8); opacity: 0; }
  }

  .visual-test-pattern {
    width: 480px;
    height: 480px;
    margin-right: -120px;
    background: repeating-conic-gradient(
      from 0deg,
      rgba(255,255,255,0.08) 0deg 90deg,
      transparent 90deg 180deg
    );
    border: 4px solid rgba(255,255,255,0.08);
    border-radius: 50%;
    animation: atomicSpin 35s linear infinite;
    flex-shrink: 0;
  }

  .explore-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.5rem 1rem;
    background: white;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--text-primary);
    transition: all var(--transition-medium);
    text-align: center;
  }

  .explore-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent-primary);
    color: var(--text-primary);
  }

  .explore-icon {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .explore-label {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
  }

  .explore-desc {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-warm-gray);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    .hero-name { font-size: 3.25rem; }
    .articles-grid { grid-template-columns: 1fr; }
    .explore-grid { grid-template-columns: repeat(2, 1fr); }
    
    .app-promo-visual { height: 220px; }
    .app-promo-overlay { padding: 1.5rem; gap: 1rem; }
    .app-promo-icon { font-size: 3.5rem; }
    .app-promo-title { font-size: 1.75rem; }
    .app-promo-tag { font-size: 0.75rem; }
    .app-promo-content { padding: 1.75rem; }
    
    .visual-waves span { right: -50px; width: 150px; height: 150px; }
    .visual-test-pattern { width: 340px; height: 340px; margin-right: -80px; }
  }

</style>
