    height: auto;
    display: block;
  }

  .img-caption {
    padding: 0.75rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-warm-gray);
    background: white;
    border-top: 1px solid var(--border-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Image placeholders */
  .article-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin: 2rem 0;
    position: relative;
  }

  .city-pop-hero {
    height: 240px;
    background: linear-gradient(135deg, #E76F51, #E9C46A, #F4A261);
  }

  .city-pop-vinyl {
    height: 180px;
    background: linear-gradient(135deg, #264653, #2A9D8F);
  }

  .city-pop-neon {
    height: 200px;
    background: linear-gradient(135deg, #E76F51, #264653);
  }

  .img-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.15);
  }

  .img-label {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    color: white;
    text-shadow: 0 1px 8px rgba(0,0,0,0.3);
    letter-spacing: 0.05em;
  }

  .article-lead {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text-primary);
    font-weight: 400;
  }

  /* Listening guide */
  .listening-guide {
    margin: 1.5rem 0;
  }

  .listening-item {
    padding: 1rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .listening-item strong {
    display: block;
    font-family: var(--font-heading);
    margin-bottom: 0.25rem;
    color: var(--text-primary);
  }

  .listening-item p {
    font-size: 0.9rem;
    margin-bottom: 0;
  }

  .article-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
