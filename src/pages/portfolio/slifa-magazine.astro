---
import Layout from '../../layouts/Layout.astro';
import { portfolioItems } from '../../data/portfolio';

const item = portfolioItems.find(i => i.slug === 'slifa-magazine')!;
---

<Layout title={item.title} description={item.tagline}>
  <nav class="breadcrumb">
    <a href="/portfolio">Portfolio</a>
    <span class="breadcrumb-sep">→</span>
    <span class="breadcrumb-current">{item.title}</span>
  </nav>

  <div class="project-hero" style={`background: ${item.color}`}>
    <span class="project-hero-icon">{item.icon}</span>
    <h1>{item.title}</h1>
    <p class="project-hero-tagline">{item.tagline}</p>
  </div>

  <div class="project-content article-content">
    <div class="project-meta">
      <div class="meta-item">
        <span class="meta-label">Role</span>
        <span class="meta-value">{item.details.role}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Year</span>
        <span class="meta-value">{item.details.year}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Tools</span>
        <span class="meta-value">{item.details.tools.join(', ')}</span>
      </div>
    </div>

    <div class="jet-line"><span>◆</span></div>

    <h2>Overview</h2>
    <p>{item.details.overview}</p>

    <div class="project-image-placeholder">
      <div class="placeholder-pattern">
        <span>✦</span>
        <span>◎</span>
        <span>◈</span>
      </div>
      <p>Magazine spread mockup</p>
    </div>

    <h2>Key Features</h2>
    <ul class="feature-list">
      {item.details.features.map((f) => (
        <li>{f}</li>
      ))}
    </ul>

    <div class="project-nav mt-4">
      <a href="/portfolio" class="btn">← All Projects</a>
    </div>
  </div>
</Layout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin-bottom: 1.5rem;
    color: var(--color-warm-gray);
  }
  .breadcrumb a { color: var(--accent-primary); }
  .breadcrumb-sep { opacity: 0.5; }

  .project-hero {
    border-radius: var(--radius-lg);
    padding: 3rem 2rem;
    text-align: center;
    color: white;
    margin-bottom: 2rem;
  }
  .project-hero-icon { font-size: 3rem; display: block; margin-bottom: 1rem; opacity: 0.9; }
  .project-hero h1 { color: white; font-size: 2.25rem; margin-bottom: 0.5rem; }
  .project-hero-tagline { font-size: 1.1rem; opacity: 0.85; font-weight: 300; }

  .project-content { max-width: 800px; }

  .project-meta {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .meta-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-warm-gray);
    margin-bottom: 0.2rem;
  }
  .meta-value {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .project-image-placeholder {
    background: var(--bg-secondary);
    border: 1px dashed var(--border-color);
    border-radius: var(--radius-lg);
    padding: 3rem;
    text-align: center;
    margin: 1.5rem 0;
  }
  .placeholder-pattern {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 2rem;
    color: var(--accent-primary);
    opacity: 0.3;
    margin-bottom: 0.75rem;
  }
  .project-image-placeholder p {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-warm-gray);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .feature-list {
    list-style: none;
    padding: 0;
  }
  .feature-list li {
    padding: 0.5rem 0 0.5rem 1.25rem;
    position: relative;
    font-size: 0.95rem;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-color);
  }
  .feature-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent-primary);
  }
</style>
