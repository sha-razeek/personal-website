---
import Layout from '../layouts/Layout.astro';
---

<Layout title="World Map" description="A zoomable vector world map in mid-century modern style">
  <div class="page-header">
    <h1>Cartography</h1>
    <p class="subtitle">Global vector coordinates  -  Admin 0 Boundaries</p>
  </div>

  <div class="map-container">
    <div id="map-controls">
      <button class="btn btn--small" id="zoom-in">+</button>
      <button class="btn btn--small" id="zoom-out">−</button>
      <button class="btn btn--small" id="zoom-reset">Reset</button>
    </div>
    
    <div id="map-viewport">
      <div id="map-loading">Initialising global coordinates...</div>
      <svg id="world-map"></svg>
    </div>

    <div id="country-info">
      <div class="info-label">📍 Selection Detected:</div>
      <div id="country-name" class="info-value">Select a territory...</div>
    </div>
  </div>
</Layout>

<script>
  import * as d3 from 'd3';

  // Map configuration
  const width = 900;
  const height = 500;
  // Using a more reliable GeoJSON source
  const geojsonUrl = 'https://raw.githubusercontent.com/holtzy/D3-graph-gallery/master/DATA/world.geojson';

  async function initMap() {
    const svg = d3.select('#world-map');
    const loading = document.getElementById('map-loading');
    const infoDisplay = document.getElementById('country-name');
    
    if (!svg.node()) return;

    svg.attr('viewBox', `0 0 ${width} ${height}`)
       .attr('preserveAspectRatio', 'xMidYMid meet');

    const g = svg.append('g');

    // Projection
    const projection = d3.geoNaturalEarth1()
      .scale(160)
      .translate([width / 2, height / 2]);

    const path = d3.geoPath().projection(projection);

    // Zoom behavior
    const zoom = d3.zoom()
      .scaleExtent([1, 8])
      .on('zoom', (event) => {
        g.attr('transform', event.transform);
      });

    svg.call(zoom);

    try {
      const data = await d3.json(geojsonUrl);

      if (loading) loading.style.display = 'none';

      // Draw background
      g.append('path')
        .datum({type: 'Sphere'})
        .attr('class', 'sphere')
        .attr('d', path);

      // Draw grid
      g.append('path')
        .datum(d3.geoGraticule())
        .attr('class', 'graticule')
        .attr('d', path);

      // Draw countries
      g.selectAll('path.country')
        .data(data.features)
        .enter()
        .append('path')
        .attr('class', 'country')
        .attr('d', path)
        .on('click', function(event, d) {
          d3.selectAll('.country').classed('selected', false);
          d3.select(this).classed('selected', true);
          
          if (infoDisplay) {
            infoDisplay.innerText = d.properties.name || 'Unknown Territory';
            infoDisplay.classList.remove('pulse');
            void infoDisplay.offsetWidth;
            infoDisplay.classList.add('pulse');
          }
          event.stopPropagation();
        });

      // Controls
      document.getElementById('zoom-in')?.addEventListener('click', () => svg.transition().call(zoom.scaleBy, 1.5));
      document.getElementById('zoom-out')?.addEventListener('click', () => svg.transition().call(zoom.scaleBy, 0.7));
      document.getElementById('zoom-reset')?.addEventListener('click', () => svg.transition().call(zoom.transform, d3.zoomIdentity));

    } catch (error) {
      console.error('Map loading failed:', error);
      if (loading) {
        loading.innerText = 'Unable to load map data. Please check your connection.';
        loading.style.color = 'var(--color-coral)';
      }
    }
  }

  // Ensure init runs
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMap);
  } else {
    initMap();
  }
</script>

<style>
  .map-container {
    position: relative;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-top: 2rem;
    box-shadow: var(--shadow-sm);
  }

  #map-viewport {
    width: 100%;
    height: 60vh;
    min-height: 400px;
    cursor: grab;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #map-loading {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-warm-gray);
    z-index: 5;
    pointer-events: none;
  }

  #map-viewport:active {
    cursor: grabbing;
  }

  #world-map {
    width: 100%;
    height: 100%;
  }

  /* Map Aesthetics */
  .sphere {
    fill: #fdfdfd;
    opacity: 0.5;
  }

  .graticule {
    fill: none;
    stroke: var(--border-color);
    stroke-width: 0.5px;
    stroke-dasharray: 2, 2;
  }

  .country {
    fill: var(--accent-primary);
    fill-opacity: 0.7;
    stroke: white;
    stroke-width: 0.5px;
    transition: all var(--transition-fast);
  }

  .country:hover {
    fill-opacity: 1;
    fill: var(--accent-secondary);
    cursor: pointer;
  }

  .country.selected {
    fill: var(--accent-warm);
    fill-opacity: 1;
    stroke: var(--text-primary);
    stroke-width: 1px;
  }

  /* Controls */
  #map-controls {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    z-index: 10;
  }

  /* Info Bar */
  #country-info {
    padding: 1.5rem 2rem;
    background: white;
    border-top: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .info-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-warm-gray);
  }

  .info-value {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .pulse {
    animation: textHighlight 0.4s var(--ease-out);
  }

  @keyframes textHighlight {
    0% { transform: translateY(5px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  @media (max-width: 768px) {
    #map-viewport { height: 50vh; }
    #country-info { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
  }
</style>
