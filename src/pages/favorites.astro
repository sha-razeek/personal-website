---
import Layout from '../layouts/Layout.astro';
import { favorites } from '../data/favorites';

const sections = [
  { id: 'book', label: 'Books', icon: '📖' },
  { id: 'movie', label: 'Movies', icon: '🎬' },
  { id: 'tv', label: 'TV Shows', icon: '📺' },
  { id: 'music', label: 'Music', icon: `<svg width="16" height="16" viewBox="0 0 164 153" fill="none" xmlns="http://www.w3.org/2000/svg" style="display: inline-block;"><g><path d="M99.1721 13.564C99.3179 13.5731 99.4635 13.5837 99.6091 13.5958C102.251 13.8165 102.96 15.5127 104.211 17.5868C105.815 20.2447 107.383 23.1732 109.508 25.4607C112.233 28.4162 115.633 30.6685 119.417 32.0254C122.672 33.1866 128.989 34.488 126.517 39.4104C125.627 41.1835 124.601 41.5477 122.788 42.1171C114.185 40.6196 110.737 37.8718 103.963 32.7557C104.165 45.1096 103.876 57.7554 103.969 70.163C104.03 78.142 104.345 87.649 103.296 95.4482C102.787 99.2327 100.609 104.138 98.1743 107.103C92.1085 114.491 86.7581 117.132 77.5628 118.259C69.7081 118.647 62.826 116.707 56.8529 111.446C51.225 106.552 47.7703 99.6238 47.2481 92.184C46.7593 84.4211 48.981 77.0913 54.1697 71.2232C59.1521 65.6068 66.164 62.2032 73.659 61.763C81.6607 61.2856 89.0358 63.9075 95.0335 69.2261C95.2888 57.7363 94.9645 45.9583 95.086 34.4412C95.1362 29.0507 94.9268 23.6458 95.1882 18.261C95.3421 15.0902 96.0907 14.1279 99.1721 13.564Z" fill="currentColor"/><path d="M73.5962 70.5726C84.331 69.5289 93.8802 77.3832 94.9274 88.1176C95.9745 98.8521 88.1234 108.404 77.3893 109.454C66.6503 110.506 57.0932 102.65 56.0455 91.9107C54.9978 81.1713 62.8565 71.6168 73.5962 70.5726Z" fill="currentColor"/></g></svg>` },
];

const getItemsByType = (type: string) => favorites.filter(item => item.type === type);
---

<Layout title="Favorites" description="Recommended books, movies, TV shows, and music albums by Sha Razeek">
  <div class="page-header">
    <h1>Favorites</h1>
    <p class="subtitle">A curated collection of beautiful things that have inspired, and entertained me</p>
  </div>

  <div class="favorites-content">
    {sections.map(section => {
      const items = getItemsByType(section.id);
      if (items.length === 0) return null;
      
      return (
        <section class="fav-section">
          <div class="section-header">
            <h2 class="fav-section-title">
              <span class="fav-section-icon">{section.icon}</span>
              {section.label}
            </h2>
          </div>
          
          <div class="favorites-grid">
            {items.map((item) => (
              <div class="card favorite-card" data-type={item.type}>
                <div class="favorite-image-container">
                  <img 
                    src={item.coverImage || `https://placehold.co/${item.type === 'music' ? '400x400' : '400x600'}/f4f1ea/264653?text=${encodeURIComponent(item.title)}`} 
                    alt={item.title} 
                    class="favorite-img"
                  />
                </div>
                
                  <div class="favorite-card-body">
                    <div class="favorite-header">
                      <h3>{item.title}</h3>
                      {item.year && <span class="favorite-year">{item.year}</span>}
                    </div>
                    
                    <p class="favorite-creator">{item.creator}</p>
                    
                    {item.description && <p class="favorite-desc">{item.description}</p>}

                    {item.country && (
                      <div class="favorite-meta">
                        <span class="country-tag">📍 {item.country}</span>
                      </div>
                    )}
                  </div>
              </div>
            ))}
          </div>
        </section>
      );
    })}
  </div>
</Layout>

<style>
  .favorites-content {
    max-width: 960px;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .fav-section {
    display: flex;
    flex-direction: column;
  }

  .fav-section-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.8rem;
    margin-bottom: 2rem;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.75rem;
  }

  .fav-section-icon {
    font-size: 1.5rem;
  }

  /* Grid and Cards */
  .favorites-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .favorite-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    height: 100%;
    position: relative;
    border-top: 4px solid var(--border-color);
    transition: all var(--transition-medium);
    overflow: hidden;
  }

  .favorite-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-top-color: var(--accent-primary);
  }

  .favorite-image-container {
    width: 100%;
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Aspect ratios: 1:1 for music, 2:3 for others */
  .favorite-card[data-type="music"] .favorite-image-container {
    aspect-ratio: 1 / 1;
  }
  
  .favorite-card:not([data-type="music"]) .favorite-image-container {
    aspect-ratio: 2 / 3;
  }

  .favorite-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-medium);
  }

  .favorite-card:hover .favorite-img {
    transform: scale(1.05);
  }

  .favorite-card-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .favorite-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.25rem;
  }

  .favorite-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0;
    color: var(--text-primary);
  }

  .favorite-year {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-warm-gray);
    white-space: nowrap;
  }

  .favorite-meta {
    margin-top: auto;
    padding-top: 1rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .country-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent-primary);
    background: rgba(42, 157, 143, 0.06);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .favorite-creator {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--accent-primary);
    margin-bottom: 1rem;
  }

  .favorite-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 0;
  }

  /* Specific border colors for types */
  .favorite-card[data-type="book"] { border-top-color: var(--accent-warm); }
  .favorite-card[data-type="movie"] { border-top-color: var(--accent-secondary); }
  .favorite-card[data-type="tv"] { border-top-color: var(--color-charcoal); }
  .favorite-card[data-type="music"] { border-top-color: var(--accent-primary); }

  @media (max-width: 768px) {
    .favorites-grid {
      grid-template-columns: 1fr;
    }
    
    .favorites-content {
      gap: 3rem;
    }

    .fav-section-title {
      font-size: 1.5rem;
    }
  }
</style>
