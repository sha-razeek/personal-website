---
const { pathname } = Astro.url;
const normalizedPath = pathname.replace(/\/$/, '') || '/';

const navItems = [
  { href: '/', label: 'Home', icon: '◈' },
  { 
    href: '/about', 
    label: 'About', 
    icon: '◇',
    children: [
      { href: '/resume', label: 'Resume', icon: '▣' },
      { href: '/portfolio', label: 'Portfolio', icon: '◎' },
    ]
  },
  { href: '/favorites', label: 'Favorites', icon: '★' },
  { 
    href: '/music/transistor', 
    label: 'Transistor', 
    icon: `<svg width="20" height="20" viewBox="0 0 25 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M4.01136 4.41225C5.01168 3.45295 6.41095 3 8.02051 3H16.4785C18.0877 3 19.4882 3.46255 20.4889 4.43655C21.4929 5.41376 22 6.81388 22 8.4981V15.5872C22 17.2511 21.4906 18.6318 20.4837 19.5931C19.4821 20.5492 18.0832 20.9996 16.4785 20.9996H8.01176C6.40339 20.9996 5.00368 20.5495 4.0038 19.5923C2.99876 18.6302 2.49493 17.2489 2.50004 15.586V8.42221C2.50004 6.75907 3.0062 5.37618 4.01136 4.41225ZM5.04958 5.49488C4.40604 6.11203 4.00004 7.06524 4.00004 8.42221V15.5872L4.00003 15.5896C3.99567 16.9453 4.39963 17.8947 5.04108 18.5088C5.68796 19.1281 6.67396 19.4996 8.01176 19.4996H16.4785C17.8113 19.4996 18.7981 19.1284 19.4479 18.5081C20.0924 17.8929 20.5 16.9424 20.5 15.5872V8.4981C20.5 7.11551 20.0901 6.14158 19.4427 5.51144C18.792 4.8781 17.8068 4.5 16.4785 4.5H8.02051C6.68392 4.5 5.69795 4.8731 5.04958 5.49488Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M9.05078 16.1406C9.05078 15.7264 9.38657 15.3906 9.80078 15.3906H14.6977C15.112 15.3906 15.4477 15.7264 15.4477 16.1406C15.4477 16.5548 15.112 16.8906 14.6977 16.8906H9.80078C9.38657 16.8906 9.05078 16.5548 9.05078 16.1406Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M11.3828 11.9819C11.3828 11.5046 11.7701 11.1191 12.2458 11.1191C12.7215 11.1191 13.1088 11.5046 13.1088 11.9819C13.1088 12.4585 12.7224 12.8449 12.2458 12.8449C11.7692 12.8449 11.3828 12.4585 11.3828 11.9819Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M11.3828 8.59324C11.3828 8.11591 11.7701 7.73047 12.2458 7.73047C12.7215 7.73047 13.1088 8.11591 13.1088 8.59324C13.1088 9.06987 12.7224 9.45622 12.2458 9.45622C11.7692 9.45622 11.3828 9.06987 11.3828 8.59324Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M6.93555 11.9819C6.93555 11.5046 7.32282 11.1191 7.79853 11.1191C8.27425 11.1191 8.66151 11.5046 8.66151 11.9819C8.66151 12.4585 8.27516 12.8449 7.79853 12.8449C7.3219 12.8449 6.93555 12.4585 6.93555 11.9819Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M6.93555 8.59324C6.93555 8.11591 7.32282 7.73047 7.79853 7.73047C8.27425 7.73047 8.66151 8.11591 8.66151 8.59324C8.66151 9.06987 8.27516 9.45622 7.79853 9.45622C7.3219 9.45622 6.93555 9.06987 6.93555 8.59324Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M15.8379 11.9819C15.8379 11.5046 16.2252 11.1191 16.7009 11.1191C17.1766 11.1191 17.5639 11.5046 17.5639 11.9819C17.5639 12.4585 17.1775 12.8449 16.7009 12.8449C16.2242 12.8449 15.8379 12.4585 15.8379 11.9819Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M15.8379 8.59324C15.8379 8.11591 16.2252 7.73047 16.7009 7.73047C17.1766 7.73047 17.5639 8.11591 17.5639 8.59324C17.5639 9.06987 17.1775 9.45622 16.7009 9.45622C16.2242 9.45622 15.8379 9.06987 15.8379 8.59324Z" fill="currentColor"/></svg>`, 
    featured: true 
  },
  { 
    href: '/projects/broadcast', 
    label: 'Broadcast', 
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M16.9719 20.7939H7.02908C4.80389 20.7939 3 18.99 3 16.7648V11.3084C3 9.08319 4.80389 7.2793 7.02908 7.2793H16.9719C19.1961 7.2793 21 9.08319 21 11.3084V16.7648C21 18.99 19.1961 20.7939 16.9719 20.7939Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M17.9844 16.9358V16.9258" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M17.9844 11.1565V11.1465" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M17.9844 14.0471V14.0371" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M13.2691 17.9797H8.00147C6.9059 17.9797 6.01758 17.0914 6.01758 15.9958V12.0786C6.01758 10.9821 6.9059 10.0938 8.00147 10.0938H13.2691C14.3647 10.0938 15.253 10.9821 15.253 12.0786V15.9958C15.253 17.0914 14.3647 17.9797 13.2691 17.9797Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M16.4961 3.20703L11.9436 7.28184L7.50586 3.20703" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`, 
    featured: true 
  },
  { href: '/music', label: 'Music', icon: `<svg width="20" height="20" viewBox="0 0 164 153" fill="none" xmlns="http://www.w3.org/2000/svg"><g><path d="M99.1721 13.564C99.3179 13.5731 99.4635 13.5837 99.6091 13.5958C102.251 13.8165 102.96 15.5127 104.211 17.5868C105.815 20.2447 107.383 23.1732 109.508 25.4607C112.233 28.4162 115.633 30.6685 119.417 32.0254C122.672 33.1866 128.989 34.488 126.517 39.4104C125.627 41.1835 124.601 41.5477 122.788 42.1171C114.185 40.6196 110.737 37.8718 103.963 32.7557C104.165 45.1096 103.876 57.7554 103.969 70.163C104.03 78.142 104.345 87.649 103.296 95.4482C102.787 99.2327 100.609 104.138 98.1743 107.103C92.1085 114.491 86.7581 117.132 77.5628 118.259C69.7081 118.647 62.826 116.707 56.8529 111.446C51.225 106.552 47.7703 99.6238 47.2481 92.184C46.7593 84.4211 48.981 77.0913 54.1697 71.2232C59.1521 65.6068 66.164 62.2032 73.659 61.763C81.6607 61.2856 89.0358 63.9075 95.0335 69.2261C95.2888 57.7363 94.9645 45.9583 95.086 34.4412C95.1362 29.0507 94.9268 23.6458 95.1882 18.261C95.3421 15.0902 96.0907 14.1279 99.1721 13.564Z" fill="currentColor"/><path d="M73.5962 70.5726C84.331 69.5289 93.8802 77.3832 94.9274 88.1176C95.9745 98.8521 88.1234 108.404 77.3893 109.454C66.6503 110.506 57.0932 102.65 56.0455 91.9107C54.9978 81.1713 62.8565 71.6168 73.5962 70.5726Z" fill="currentColor"/></g></svg>` },
  { href: '/blog', label: 'Articles', icon: '✦' },
  { href: '/gear', label: 'My Gear', icon: '⌨' },
  { href: '/projects', label: 'Projects', icon: '⬡' },
  { href: '/trivia', label: 'Trivia', icon: '☆' },
];
---
<!-- Mobile overlay -->
<div id="sidebar-overlay" class="sidebar-overlay"></div>

<!-- Mobile toggle button -->
<button id="sidebar-toggle" class="sidebar-toggle" aria-label="Toggle menu">
  <span class="hamburger-line"></span>
  <span class="hamburger-line"></span>
  <span class="hamburger-line"></span>
</button>

<aside id="sidebar" class="sidebar">
  <div class="sidebar-inner">
    <!-- Logo / Identity -->
    <a href="/" class="sidebar-brand">
      <div class="brand-icon">
        <svg width="40" height="40" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Starburst / Atomic motif -->
          <circle cx="16" cy="16" r="2.5" fill="currentColor"/>
          <circle cx="16" cy="16" r="7" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2.5"/>
          <circle cx="16" cy="16" r="13" stroke="currentColor" stroke-width="0.75" stroke-dasharray="1.5 3"/>
          <path d="M16 1 L16.8 5 L15.2 5 Z" fill="currentColor" opacity="0.7"/>
          <path d="M16 31 L16.8 27 L15.2 27 Z" fill="currentColor" opacity="0.7"/>
          <path d="M1 16 L5 15.2 L5 16.8 Z" fill="currentColor" opacity="0.7"/>
          <path d="M31 16 L27 15.2 L27 16.8 Z" fill="currentColor" opacity="0.7"/>
          <path d="M5.4 5.4 L8.3 7.3 L7.3 8.3 Z" fill="currentColor" opacity="0.5"/>
          <path d="M26.6 26.6 L23.7 24.7 L24.7 23.7 Z" fill="currentColor" opacity="0.5"/>
          <path d="M26.6 5.4 L24.7 8.3 L23.7 7.3 Z" fill="currentColor" opacity="0.5"/>
          <path d="M5.4 26.6 L7.3 23.7 L8.3 24.7 Z" fill="currentColor" opacity="0.5"/>
        </svg>
      </div>
      <div class="brand-text">
        <span class="brand-name">Sha Razeek</span>
        <span class="brand-title">Developer & Designer</span>
      </div>
    </a>

    <!-- Navigation -->
    <nav class="sidebar-nav">
      {navItems.map(item => {
        const isCurrentParent = normalizedPath === item.href;
        const hasActiveChild = item.children && item.children.some(c => c.href === normalizedPath);
        const isActive = isCurrentParent || hasActiveChild;
        
        // For 'About', we only show children if we are in the About section (Parent or Child active)
        // For others, we keep them always visible for better UX
        const showChildren = item.children && (item.href === '/about' ? isActive : true);

        return (
          <div class="nav-group">
            <a href={item.href} class={`nav-link ${isActive ? 'active' : ''} ${item.featured ? 'nav-link--featured' : ''}`}>
              <span class="nav-icon" set:html={item.icon}></span>
              <span class="nav-label">{item.label}</span>
              <span class="nav-arrow">→</span>
            </a>            {showChildren && (
                <div class="nav-sub">
                  {item.children.map(child => {
                    const isChildActive = normalizedPath === child.href;
                    return (
                      <a href={child.href} class={`nav-link nav-link--sub ${isChildActive ? 'active' : ''}`}>
                        <span class="nav-icon nav-icon--sub" set:html={child.icon}></span>
                        <span class="nav-label">{child.label}</span>
                      </a>
                    );
                  })}
                </div>
              )}          </div>
        );
      })}
    </nav>

    <!-- Footer info -->
    <div class="sidebar-footer">
      <div class="jet-line-sidebar"></div>
      <p class="sidebar-tagline">Hypermedia & UI/UX</p>
      <p class="sidebar-location">✦ Available for work</p>
    </div>
  </div>
</aside>

<style>
  /* ---- Sidebar Overlay (mobile) ---- */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(38, 70, 83, 0.3);
    backdrop-filter: blur(2px);
    z-index: 90;
    opacity: 0;
    transition: opacity var(--transition-medium);
  }

  .sidebar-overlay.active {
    display: block;
    opacity: 1;
  }

  /* ---- Mobile Toggle ---- */
  .sidebar-toggle {
    display: none;
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 100;
    width: 40px;
    height: 40px;
    background: white;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    cursor: pointer;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-fast);
  }

  .sidebar-toggle:hover {
    box-shadow: var(--shadow-md);
  }

  .hamburger-line {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--text-primary);
    transition: all var(--transition-fast);
  }

  /* ---- Sidebar ---- */
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 260px;
    height: 100vh;
    background: white;
    border-right: 1px solid var(--border-color);
    z-index: 95;
    overflow-y: auto;
    transition: transform var(--transition-medium);
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 2rem 0;
  }

  /* ---- Brand ---- */
  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0 1.5rem;
    margin-bottom: 2.5rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: opacity var(--transition-fast);
  }

  .sidebar-brand:hover {
    opacity: 0.8;
    color: var(--text-primary);
  }

  .brand-icon {
    color: var(--accent-primary);
    flex-shrink: 0;
    animation: starburstPulse 4s ease-in-out infinite;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
  }

  .brand-name {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .brand-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-warm-gray);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ---- Navigation ---- */
  .sidebar-nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 0 0.75rem;
    gap: 2px;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.7rem 0.85rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 1.05rem;
    font-weight: 500;
    transition: all var(--transition-fast);
    position: relative;
  }

  .nav-link:hover {
    background: rgba(42, 157, 143, 0.06);
    color: var(--text-primary);
  }

  .nav-link:hover .nav-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .nav-link.active {
    background: rgba(42, 157, 143, 0.1);
    color: var(--accent-primary);
    font-weight: 600;
  }

  .nav-link--featured {
    background: rgba(231, 111, 81, 0.08); /* Light Coral background */
    color: var(--accent-secondary);
    border: 1px solid rgba(231, 111, 81, 0.15);
    margin-top: 4px;
    margin-bottom: 4px;
  }

  .nav-link--featured:hover {
    background: rgba(231, 111, 81, 0.12);
    border-color: var(--accent-secondary);
  }

  .nav-link--featured.active {
    background: var(--accent-secondary);
    color: white;
    border-color: var(--accent-secondary);
  }

  .nav-link--featured.active .nav-arrow {
    color: white;
  }

  .nav-link.active::before {
    content: '';
    position: absolute;
    left: -0.85rem;
    top: 50%;
    transform: translateY(-50%);
    width: 3.5px;
    height: 24px;
    background: var(--accent-primary);
    border-radius: 0 2px 2px 0;
  }

  /* Sub-links */
  .nav-group {
    display: flex;
    flex-direction: column;
  }

  .nav-sub {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 2px;
    margin-bottom: 8px;
  }

  .nav-link--sub {
    padding-left: 2.75rem;
    font-size: 0.95rem;
    color: var(--text-secondary);
    opacity: 0.85;
    min-height: auto;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .nav-link--sub:hover {
    opacity: 1;
    background: rgba(42, 157, 143, 0.04);
  }

  .nav-link--sub.active {
    opacity: 1;
    background: transparent;
    color: var(--accent-primary);
  }

  .nav-link--sub.active::before {
    height: 16px;
  }

  .nav-icon--sub {
    font-size: 0.95rem;
    width: 1.25rem;
  }

  .nav-icon {
    font-size: 1.1rem;
    width: 1.5rem;
    text-align: center;
    flex-shrink: 0;
  }

  .nav-label {
    flex: 1;
  }

  .nav-arrow {
    font-size: 0.85rem;
    opacity: 0;
    transform: translateX(-4px);
    transition: all var(--transition-fast);
    color: var(--accent-primary);
  }

  /* ---- Footer ---- */
  .sidebar-footer {
    padding: 1.5rem 1.5rem 0;
    margin-top: auto;
  }

  .jet-line-sidebar {
    height: 1px;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary), var(--accent-warm));
    margin-bottom: 1rem;
    opacity: 0.4;
  }

  .sidebar-tagline {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-warm-gray);
    margin-bottom: 0.25rem;
  }

  .sidebar-location {
    font-size: 0.8rem;
    color: var(--accent-primary);
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .sidebar {
      transform: translateX(-100%);
    }

    .sidebar.open {
      transform: translateX(0);
      box-shadow: var(--shadow-lg);
    }

    .sidebar-toggle {
      display: flex;
    }
  }
</style>
